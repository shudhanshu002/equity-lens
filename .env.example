# ==========================================
# EquityLens AI Environment Configurations
# ==========================================

# 1. API Keys & Models
# --------------------
# Alpha Vantage API key (for public stock fundamentals and balance sheets)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Google Gemini API key (for langchain memos and reasoning)
GOOGLE_API_KEY=your_google_gemini_api_key_here
GOOGLE_MODEL=gemini-2.5-flash

# Finnhub API key (for real-time stock news)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Serper API key (required for web-search ticker discovery and private company research)
SERPER_API_KEY=your_serper_api_key_here


# 2. Database Connection
# ----------------------
# Prisma-compatible connection URL (Neon or Supabase PostgreSQL recommended)
DATABASE_URL="postgresql://username:password@hostname/neondb?sslmode=require"


# 3. NextAuth Authentication
# ---------------------------
# Generate a secret via: openssl rand -base64 32
NEXTAUTH_SECRET=your_random_nextauth_secret_key

# Set to http://localhost:3000 locally, or your https://your-domain.vercel.app in production
NEXTAUTH_URL=http://localhost:3000


# 4. Live SMTP (Mail Relay)
# --------------------------
# Configures OTP verification, signup authentication, and password resets.
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_your_smtp_password_or_resend_api_key
SMTP_FROM="EquityLens AI <onboarding@resend.dev>"


# 5. Administration & System Settings
# -----------------------------------
# Used to promote your own user account to ADMIN via /api/admin/promote-self
ADMIN_SETUP_TOKEN=your_secure_administrative_setup_token_here

# Set to "production" in live environments, or "development" locally
NODE_ENV=development
